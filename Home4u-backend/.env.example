# =====================================================
# Home4U Backend - 환경변수 템플릿
# -----------------------------------------------------
# 사용법:
#   1. 이 파일을 .env 로 복사
#        cp .env.example .env
#   2. 각 값을 실제 값으로 채운다
#   3. 쉘에서 로드해서 Spring Boot 실행
#        set -a && source .env && set +a && ./gradlew bootRun
#      (또는 IDE 의 Run Configuration → Environment Variables 에 등록)
#
# .env 는 .gitignore 에 포함되어 있어 커밋되지 않는다.
# 실제 값을 이 .env.example 에 채워 넣지 말 것.
# =====================================================

# ---- JWT (필수 — 운영) ----
# 256bit(32바이트) 이상의 랜덤 문자열 권장
# 미설정 시 application.properties 의 개발용 기본값이 쓰이며,
# 이 기본값은 운영 환경에서 절대 사용하지 말 것.
JWT_SECRET=

# ---- DB (MySQL 프로파일만 해당) ----
# SPRING_PROFILES_ACTIVE=mysql 로 실행할 때만 읽힌다. 기본(dev)은 H2 인메모리.
SPRING_PROFILES_ACTIVE=dev
MYSQL_USER=root
MYSQL_PASSWORD=

# ---- OAuth: Naver 로그인 (선택) ----
# 값이 비어 있으면 OAuth 관련 기능만 비활성되고 나머지는 동작.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ---- ChatGPT 챗봇 (선택) ----
OPENAI_API_KEY=
